# SIGAP Backend Environment Variables Template
# Copy this file to .env and fill in your actual credentials

# Database Connection (MySQL)
# Example: mysql://user:password@localhost:3306/db_name
DATABASE_URL="mysql://root:password@localhost:3306/sigap_db"

# JWT Secret for Token Encryption (You can use any random string)
JWT_SECRET="your_random_secret_string_here"

# Gemini AI API Key (Get it from Google AI Studio)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# Google Auth Client ID (Get it from Google Cloud Console)
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID_HERE"
